{
  "name": "tenzu",
  "version": "0.0.1-staging.5",
  "schematics": "schematics/collection.json",
  "scripts": {
    "ng": "ng",
    "start": "node ./init-config.js  && ng serve  tenzu --hmr --host 0.0.0.0 --allowed-hosts true",
    "build": "ng build && npm run sentry:sourcemaps",
    "build-schematics": "./node_modules/.bin/tsc -p ./tsconfig.schematics.json",
    "schematics:add-plugins": "schematics ./src/schematics/collection.json:add-plugins --no-dry-run",
    "schematics:reset-plugins": "schematics ./src/schematics/collection.json:reset-plugins --no-dry-run",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:coverage": "ng --no-watch --code-coverage",
    "test:watch": "ng test  --watch",
    "e2e:ui": "npx playwright test",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "transloco:optimize": "transloco-optimize dist/tenzu/browser/assets/i18n",
    "build:staging": "ng build --configuration staging && npm run transloco:optimize",
    "build:production": "ng build --configuration production && npm run transloco:optimize",
    "serve-prod-local": "npx http-server dist/tenzu/browser -p 4200",
    "storybook": "ng run tenzu:storybook",
    "build-storybook": "ng run tenzu:build-storybook"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.0",
    "@angular/cdk": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/material": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-browser-dynamic": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@auth0/angular-jwt": "^5.2.0",
    "@blocknote/code-block": "^0.46.1",
    "@blocknote/core": "^0.46.1",
    "@blocknote/mantine": "^0.46.1",
    "@blocknote/react": "^0.46.1",
    "@jsverse/transloco": "^8.1.0",
    "@jsverse/transloco-locale": "^8.2.0",
    "@jsverse/transloco-messageformat": "^8.2.0",
    "@mantine/core": "^8.3.9",
    "@mantine/hooks": "^8.3.9",
    "@mantine/utils": "^6.0.22",
    "@ngrx/operators": "^21.1.0",
    "@ngrx/signals": "^21.1.0",
    "@sentry/angular": "^10.34.0",
    "@y/y": "^14.0.0-16",
    "file-saver-es": "^2.0.5",
    "marked": "^18.0.5",
    "ng-event-bus": "^10.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.29",
    "zod": "^3.25.61"
  },
  "devDependencies": {
    "@angular-architects/ngrx-toolkit": "^21.0.1",
    "@angular-devkit/architect": "^0.2200.3",
    "@angular-devkit/core": "^22.0.0",
    "@angular-devkit/schematics-cli": "^22.0.3",
    "@angular-devkit/build-angular": "^22.0.3",
    "@angular-eslint/builder": "^22.0.0",
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@eslint/js": "^10.0.1",
    "@jsverse/transloco-optimize": "^8.4.0",
    "@ngrx/eslint-plugin": "^21.1.1",
    "@sentry/cli": "^3.5.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/angular": "^10.4.6",
    "@types/eslint__js": "^9.14.0",
    "@types/file-saver-es": "^2.0.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/uuid": "^10.0.0",
    "@vitest/browser-playwright": "^4.1.8",
    "angular-eslint": "^22.0.0",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.10.8",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-storybook": "^10.4.6",
    "http-serve": "^1.0.1",
    "jiti": "^2.6.1",
    "jsdom": "^27.2.0",
    "playwright": "^1.61.0",
    "postcss": "^8.4.38",
    "prettier": "^3.8.1",
    "prettier-eslint": "^17.1.1",
    "storybook": "^10.4.6",
    "tailwindcss": "^3.4.4",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.62.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "webpack": "5.106.2"
  }
}
